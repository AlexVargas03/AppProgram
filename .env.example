# Base URL of the Azure Functions API consumed by the frontend.
# Example: https://vitalwatch-func.azurewebsites.net
VITE_AZURE_API_URL=

# "true" para saltar login/registro (uid = "demo") aunque Firebase esté
# configurado abajo. Útil para la demo: llenar el config de Firebase para
# activar Firestore, pero mantener esto en "true" para no pedir login.
VITE_DEMO_MODE=

# Firebase project credentials (get from Firebase Console > Project Settings > Your apps)
# VITE_FIREBASE_PROJECT_ID es el mínimo necesario para que las escrituras de
# Firestore (src/services/firestoreLog.ts) salgan de la cola local. Sin él,
# todo queda encolado en localStorage ("sami:firestore-pending-queue").
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
