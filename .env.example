# Base URL of the Azure Functions API consumed by the frontend.
# Example: https://vitalwatch-func.azurewebsites.net
VITE_AZURE_API_URL=

# Firebase project credentials (get from Firebase Console > Project Settings > Your apps)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
