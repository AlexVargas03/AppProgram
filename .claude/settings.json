{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Glob|Grep|Bash|Agent|Read",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"try{require('fs').accessSync('graphify-out/graph.json');process.stdout.write(Buffer.from('','base64').toString())}catch(e){}\""
          }
        ]
      }
    ]
  }
}
